# =============================================================================
# ClauseGuard environment configuration
# Copy this file to .env and fill in real values. Never commit .env itself.
# =============================================================================

# ----- LLM -----
# Which provider to use. Supported: "groq" (default, recommended free tier)
# or "gemini". Adding a new provider = one branch in agent/graph.py's model
# factory, never a change to call sites — this is what keeps the app
# running with "only .env configuration, no model-specific code changes".
LLM_PROVIDER=groq

# API key for the selected provider.
# Groq: https://console.groq.com  (free, sign up, create key)
# Gemini: https://aistudio.google.com  (free tier)
LLM_API_KEY=your_api_key_here

# Model name for the selected provider.
# Groq examples: llama-3.3-70b-versatile, mixtral-8x7b-32768
# Gemini examples: gemini-1.5-flash, gemini-1.5-pro
LLM_MODEL=llama-3.3-70b-versatile

# ----- Vector Database (Qdrant Cloud, free tier) -----
# Sign up at https://cloud.qdrant.io, create a free cluster (1GB free),
# copy the cluster URL and API key from the dashboard.
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=clauseguard_contract

# ----- Embedding model -----
# Runs locally via sentence-transformers — no API key, no external service.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ----- Reranker model -----
# Also local via sentence-transformers (CrossEncoder).
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# ----- RAG pipeline tuning -----
# How many candidates to pull from Qdrant before reranking.
RETRIEVAL_TOP_K=10
# How many chunks survive reranking and get passed to the LLM as context.
RERANK_TOP_N=4

# ----- App settings -----
LOG_LEVEL=INFO
APP_ENV=development

# Path to the source contract PDF used for ingestion.
CONTRACT_PDF_PATH=./data/contract.pdf
